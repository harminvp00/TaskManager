      "updated": 1780912442852,
      "link": null,
      "locked": false,
      "text": "Example: Register features\nRequest:\n{\n    'name': \"ashish\",\n    'email': 'ashish96@gmail.com',\n    'password': \"ashish@96\"\n}\n\nResponse: \n1. success response:\n{\n    success: true,\n    user,\n    token,\n    message: 'user created successfully!'\n}\n\n2. failure response:\n{\n    success: false,\n    message: error.message\n}\n    \nAll other feature will use this structure",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "phw2xuSEpsyVnGIZb7MpA",
      "originalText": "Example: Register features\nRequest:\n{\n    'name': \"ashish\",\n    'email': 'ashish96@gmail.com',\n    'password': \"ashish@96\"\n}\n\nResponse: \n1. success response:\n{\n    success: true,\n    user,\n    token,\n    message: 'user created successfully!'\n}\n\n2. failure response:\n{\n    success: false,\n    message: error.message\n}\n    \nAll other feature will use this structure",
      "autoResize": true,
      "lineHeight": 1.25
    },
